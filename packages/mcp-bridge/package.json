{
  "name": "@bolthub/mcp-bridge",
  "version": "0.1.4",
  "description": "MCP server bridge for bolthub L402 paywalled APIs — turns gateway endpoints into MCP tools with automatic Lightning payment",
  "type": "module",
  "bin": {
    "mcp-bridge": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --sourcemap=linked",
    "prepublishOnly": "bun run build",
    "dev": "bun run src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@bolthub/agent": "workspace:*",
    "@bolthub/shared": "workspace:*",
    "@getalby/sdk": "^8.0.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3"
  },
  "keywords": [
    "mcp",
    "l402",
    "lightning",
    "bitcoin",
    "ai-agent",
    "paywall",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signaltech-org/bolthub-sdk.git",
    "directory": "packages/mcp-bridge"
  },
  "homepage": "https://docs.bolthub.ai/docs/sdks/mcp-bridge",
  "bugs": {
    "url": "https://github.com/signaltech-org/bolthub-sdk/issues"
  }
}
